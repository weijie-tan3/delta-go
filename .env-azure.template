# Azure ADLS Gen2 integration test configuration (template)
#
# Copy this file to .env-azure and fill in your values, then source it before
# running the gated integration tests:
#
#   cp .env-azure.template .env-azure
#   # edit .env-azure
#   set -a; source .env-azure; set +a
#   GOTOOLCHAIN=local go test -tags azure_integration ./storage/azurestore/ -run Integration -v
#
# Do NOT commit .env-azure (add it to .gitignore). This template carries no secrets.
#
# Authentication uses azidentity.DefaultAzureCredential. The simplest option is
# `az login`; alternatively set a service principal via AZURE_CLIENT_ID /
# AZURE_TENANT_ID / AZURE_CLIENT_SECRET (uncommented below).

# --- Required: target location -------------------------------------------------

# HNS-enabled (ADLS Gen2) storage account name.
AZURE_STORAGE_ACCOUNT=

# Filesystem (container) name.
AZURE_CONTAINER=

# Optional: root path within the container. Defaults to "delta-go-itest".
# The test appends a unique /<timestamp> per run so runs never collide.
AZURE_PATH=delta-go-itest

# --- Optional: service principal auth -----------------------------------------
# Leave these unset to use `az login` / managed identity instead.

# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
